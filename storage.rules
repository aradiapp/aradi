rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Production: only authenticated users. No time limit; not public.
    // Your existing files are still in the bucket; these rules only control access.

    // Paths your app uses (profile_pictures, listing_photos, contracts, kyc, etc.)
    match /profile_pictures/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /listing_photos/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /contracts/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /kyc/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /public/{allPaths=**} {
      allow read: if request.auth != null;
    }
    // Any other top-level folder (e.g. from file_upload_service)
    match /{folder}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
